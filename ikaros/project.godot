; Godot Engine — IKAROS
; Godot 4.3+ — open this folder as the project root.

config_version=5

[application]

config/name="IKAROS"
config/description="Mobile neon-vector physics arcade — orbit, dash, chain anchors."
config/version="0.1.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "4.6", "GL Compatibility")
config/icon="res://icons/app_icon_light.png"
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/fullsize=true
boot_splash/image=""
boot_splash/show_image=false
boot_splash/use_filter=true
boot_splash/minimum_display_time=800

[autoload]

AppIconTheme="*res://scripts/app_icon_theme.gd"
GameManager="*res://scripts/game_manager.gd"
CurrencyManager="*res://scripts/currency_manager.gd"
ItemDatabase="*res://scripts/item_database.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/vsync/vsync_mode=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="anchors"
2d_physics/layer_2="player"

[rendering]

renderer/rendering_method="gl_compatibility"
textures/canvas_textures/default_texture_filter=1
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
